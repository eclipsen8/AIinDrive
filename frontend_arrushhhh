function checkBullWeight(){
  const w=parseFloat(document.getElementById('f9-weight').value)||0;const n=document.getElementById('f9-weight-note');
  if(!w)return;
  if(w<180){n.textContent=`✗ ${w} кг < 180 кг (мин.). Субсидия не применима.`;n.className='fnote err';}
  else if(w>250){n.textContent=`⚠ ${w} кг > 250 кг (верхний порог субсидирования).`;n.className='fnote warn';}
  else{n.textContent=`✓ ${w} кг — в диапазоне 180–250 кг. Субсидия применима.`;n.className='fnote ok';S.normScore=Math.min(15,S.normScore+3);}
}

// PAGE 4
function calcResult(){
  if(S.fraud){
    document.getElementById('fraud-overlay').style.display='flex';
    document.getElementById('fraud-desc').innerHTML='Заявка заблокирована из-за обнаруженной аномалии в соотношении быков и маток. Исправьте значения перед отправкой.';
    return;
  }
  let infra=S.infraScore;
  let prod=S.prodScore||(S.subType==='f1'?18:S.subType==='f9'?15:10);
  let norm=Math.min(15,Math.max(0,S.normScore));
  let land=S.landScore;
  const total=Math.min(100,infra+prod+norm+land);
  goPage(4);

  setTimeout(()=>{
    animNum('final-score',0,total,1100);
    document.getElementById('app-num').textContent=String(31000+Math.floor(Math.random()*300));

    let status,statusColor;
    if(total>=80){status='✓ Рекомендовано к приоритетной выплате.';statusColor='var(--accent2)';}
    else if(total>=60){status='◷ Рекомендовано — вторая очередь выплаты.';statusColor='var(--gold)';}
    else{status='⚠ Требуется доработка заявки.';statusColor='var(--orange)';}

    setTimeout(()=>{
      document.getElementById('final-status').textContent=status;
      document.getElementById('final-status').style.color=statusColor;
    },1200);

    const rank=total>=80?2:total>=60?Math.floor(Math.random()*14)+5:Math.floor(Math.random()*40)+30;
    document.getElementById('shortlist-card').style.display='block';
    document.getElementById('factor-wrap').style.display='block';
    document.getElementById('result-bar').style.display='flex';
    document.getElementById('rank-pos').textContent='#'+rank;
    document.getElementById('rank-sub').textContent=`из 1500 заявок в Акмолинской области · Merit Score, а не время подачи`;

    // Why list
    const whys=[];
    if(infra>=20&&S.milkingScore>=14)whys.push({pts:'+'+infra,text:`Использование автоматизированного доильного зала (+${S.milkingScore} баллов).`});
    else if(infra>=15)whys.push({pts:'+'+infra,text:'Хорошая инфраструктура хозяйства (оборудование, водоснабжение).'});
    else whys.push({pts:'+'+infra,text:'Базовая инфраструктура.'});
    if(prod>=15)whys.push({pts:'+'+prod,text:`Рост объёмов ${S.subType==='f6'?'молока':S.subType==='f9'?'мясной продукции':'производства'} на ${prod>=25?'12%+':'до 12%'} за год.`});
    whys.push({pts:'+'+norm,text:'Соблюдение ветеринарных норм по возрасту и происхождению скота.'});
    if(land>=7)whys.push({pts:'+'+land,text:'Место в очереди: '+rank+' из 1500 (на основе Merit Score, а не времени подачи).'});
    const wl=document.getElementById('why-list');wl.innerHTML='';
    whys.forEach(w=>{wl.innerHTML+=`<div class="why-item"><div class="why-pts">${w.pts}</div><div>${w.text}</div></div>`;});

    document.getElementById('fp-infra').textContent='+'+infra;
    document.getElementById('fp-prod').textContent='+'+prod;
    document.getElementById('fp-norm').textContent='+'+norm;
    document.getElementById('fp-land').textContent='+'+land;
    document.getElementById('fd-infra').textContent=S.milkingScore>=14?`Вкл. автоматизированный доильный зал (+${S.milkingScore} б.)`:'Оборудование, водоснабжение, сертификаты';
    document.getElementById('fd-prod').textContent=prod>=25?'Рост производства +12% и более':prod>=15?'Положительная динамика производства':'Базовые показатели';

    document.getElementById('result-ai').innerHTML=
      `Итоговый балл: <strong>${total}/100</strong>. ${status}<br><br>
      • Инфраструктура (+${infra}): ${infra>=30?'Высокий уровень':infra>=15?'Средний уровень':'Низкий уровень — рекомендуем развить'}.<br>
      • Динамика производства (+${prod}): ${prod>=20?'Отличный рост — приоритетный фактор':prod>=10?'Положительная тенденция':'Нет роста'}.<br>
      • Нормы (+${norm}): ${norm>=12?'Все нормативные требования выполнены':'Частично выполнены — есть зоны роста'}.<br>
      • Земля (+${land}): ${land>=7?'Кормовая база достаточна по нормативам':'Риск недостаточности пастбищ — балл снижен'}.<br><br>
      <strong style="color:var(--accent3)">Финальное решение остаётся за комиссией Министерства сельского хозяйства РК. AI — инструмент поддержки решений, а не замена эксперта.</strong>`;
  },300);
}

function animNum(id,from,to,dur){
  const el=document.getElementById(id);const s=performance.now();
  (function u(t){const e=t-s,p=Math.min(e/dur,1),q=1-Math.pow(1-p,3);
    el.textContent=Math.round(from+(to-from)*q);if(p<1)requestAnimationFrame(u);})(s);
}
</script>
