};

function renderCL(type){
  const items=CL[type]||CL.krs;
  const wrap=document.getElementById('checklist-wrap');wrap.innerHTML='';S.checkedItems={};
  items.forEach(item=>{
    const div=document.createElement('div');
    div.className='check-item'+(item.req?' req-item':'');div.id='ci-'+item.id;
    div.onclick=()=>toggleCk(item);
    div.innerHTML=`<div class="checkbox" id="cb-${item.id}"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="#080d0b" stroke-width="3.5" style="display:none" id="sv-${item.id}"><polyline points="20 6 9 17 4 12"/></svg></div>
      <div class="check-label"><div class="check-name">${item.name}${item.req?'<span class="req-tag">ОБЯЗАТЕЛЬНО</span>':''}</div><div class="check-desc">${item.desc}</div></div>
      <div class="check-pts" id="pts-${item.id}">+${item.pts} б.</div>`;
    wrap.appendChild(div);
  });
  document.getElementById('milking-card').style.display=type==='mtf'?'block':'none';
  updInfra();
}

function toggleCk(item){
  const el=document.getElementById('ci-'+item.id);const chk=!el.classList.contains('checked');
  el.classList.toggle('checked',chk);document.getElementById('sv-'+item.id).style.display=chk?'block':'none';
  S.checkedItems[item.id]=chk?item:null;updInfra();
}

function updInfra(){
  let w=0,e=0,c=0;
  const items=CL[S.objType]||CL.krs;
  items.forEach(item=>{if(S.checkedItems&&S.checkedItems[item.id]){if(item.cat==='w')w+=item.pts;else if(item.cat==='e')e+=item.pts;else c+=item.pts;}});
  const ml=S.milkingScore||0;
  const total=Math.min(40,w+e+c+ml);S.infraScore=total;
  document.getElementById('infra-num').textContent=total;
  const circ=238.76;
  document.getElementById('score-circle').style.strokeDashoffset=circ-(total/40)*circ;
  document.getElementById('sv-w').textContent='+'+w;document.getElementById('sv-e').textContent='+'+(e+ml);document.getElementById('sv-c').textContent='+'+c;
  document.getElementById('sb-w').style.width=Math.min(100,w*8)+'%';document.getElementById('sb-e').style.width=Math.min(100,(e+ml)*3.5)+'%';document.getElementById('sb-c').style.width=Math.min(100,c*7)+'%';
  let t=`Предварительный балл: <strong>${total}/40</strong>. `;
  if(e>=12||ml>=14)t+='Наличие электронных весов / автоматизированного зала повышает доверие к данным. ';
  if(w>=7)t+='Автономное водоснабжение снижает производственные риски. ';
  if(c>=5)t+='Наличие ХАССП открывает доступ к экспортным рынкам. ';
  if(total<20)t+='<br><span style="color:var(--orange)">Рекомендация: добавьте инфраструктуру для повышения Merit Score.</span>';
  document.getElementById('audit-ai-text').innerHTML=t;
}

function selectObj(el,type){
  document.querySelectorAll('#obj-grid .type-card').forEach(c=>c.classList.remove('selected'));
  el.classList.add('selected');S.objType=type;S.milkingScore=0;renderCL(type);
}

function selectMilking(el,type,pts){
  document.querySelectorAll('#milking-grid .type-card').forEach(c=>c.classList.remove('selected'));
  el.classList.add('selected');S.milkingScore=pts;updInfra();
}

renderCL('krs');

// PAGE 3
function selectSub(el,type){
  document.querySelectorAll('#sub-grid .type-card').forEach(c=>c.classList.remove('selected'));
  el.classList.add('selected');S.subType=type;
  ['f1','f6','f9'].forEach(f=>document.getElementById('wrap-'+f).style.display=f===type?'block':'none');
}

function checkEsf(){
  const v=document.getElementById('f1-esf').value;const n=document.getElementById('f1-esf-note');
  if(v.length>8){n.textContent='✓ ЭСФ верифицирована в базе КГД — сделка подтверждена';n.className='fnote ok';}
}

function checkRatio(){
  const bulls=parseInt(document.getElementById('f1-bulls').value)||0;
  const cows=parseInt(document.getElementById('f1-cows').value)||0;
  const el=document.getElementById('ratio-alert');
  if(!bulls||!cows){el.innerHTML='';return;}
  const ratio=cows/bulls;
  if(ratio<10){
    // FRAUD detection
    el.innerHTML=`<div class="alert a-fraud">🚨 АНОМАЛИЯ — ФРОД: ${bulls} быков на ${cows} коров (соотношение 1:${Math.round(ratio)}). Норма: 1 бык на 20–30 коров. Запрос аномален → Скор = 0.</div>`;
    document.getElementById('fraud-desc').innerHTML=`ML-анализ выявил аномалию в соотношении быков и маток:<br><br>
      Запрошено: <strong>${bulls} быков</strong> на <strong>${cows} коров</strong><br>
      Соотношение: <strong>1:${Math.round(ratio)}</strong><br>
      Норма (вольная случка): <strong>1:20–30</strong><br>
      Норма (докрытие): <strong>1:100</strong><br><br>
      По нормативу на ${cows} коров достаточно <strong>${Math.ceil(cows/30)}–${Math.ceil(cows/20)} быков</strong>.<br>
      Запрос на ${bulls} быков — признак фродовой заявки. Скор обнулён до 0.`;
    document.getElementById('fraud-overlay').style.display='flex';
    S.fraud=true;S.normScore=0;
  } else if(ratio<20){
    el.innerHTML=`<div class="alert a-warn">⚠ Соотношение 1:${Math.round(ratio)} ниже нормы (мин. 1:20). Балл снижен.</div>`;
    S.fraud=false;
  } else if(ratio<=100){
    el.innerHTML=`<div class="alert a-ok">✓ Соотношение 1:${Math.round(ratio)} — в норме.</div>`;
    S.fraud=false;S.normScore+=3;
  } else {
    el.innerHTML=`<div class="alert a-warn">⚠ Соотношение 1:${Math.round(ratio)} — возможно докрытие. Уточните режим случки.</div>`;
    S.fraud=false;
  }
}

