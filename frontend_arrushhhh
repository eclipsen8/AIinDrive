function goPage(n){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-step').forEach(s=>s.classList.remove('active','done'));
  document.getElementById('page'+n).classList.add('active');
  document.getElementById('nav'+n).classList.add('active');
  for(let i=1;i<n;i++)document.getElementById('nav'+i).classList.add('done');
  window.scrollTo(0,0);
}

// PAGE 1
function onIin(el){
  el.value=el.value.replace(/\D/g,'').slice(0,12);
  const n=document.getElementById('iin-note');
  if(el.value.length===12){n.textContent='✓ Формат корректен — подключение к ГБД ЮЛ';n.className='fnote ok';}
  else{n.textContent=`Введено ${el.value.length}/12`;n.className='fnote';}
}

function loadProfile(){
  if(document.getElementById('iin').value.length<12){alert('Введите 12-значный ИИН/БИН');return;}
  if(!document.getElementById('entity-type').value){alert('Выберите тип участника');return;}
  const d={'farm-name':'КФХ «Береке-Агро»','oked':'01.41 – Разведение молочного КРС','region':'Акмолинская область','district':'Атбасарский район','cadastre':'11-098-024-312','land-total':'1 240','land-pasture':'820','cattle-total':'340','cows-total':'98','sheep-total':'120'};
  let delay=0;
  for(const[id,v] of Object.entries(d)){setTimeout(()=>{const el=document.getElementById(id);if(el){el.value='';typeVal(el,v);}},delay);delay+=90;}
  document.getElementById('profile-card').style.display='block';
  document.getElementById('p1-bottom').style.display='flex';
  setTimeout(()=>{
    const la=document.getElementById('land-alert');
    const pasture=820,cattle=340,norm=Math.round(cattle*2.1);
    if(pasture<norm){la.innerHTML=`<div class="alert a-warn">⚠ ML-фактор: Риск — площадь пастбищ ${pasture} га меньше нормы (${norm} га для ${cattle} голов КРС). Балл снижается.</div>`;S.landScore=3;}
    else{la.innerHTML=`<div class="alert a-ok">✓ Кормовая база достаточна: ${pasture} га на ${cattle} голов КРС.</div>`;S.landScore=8;}
  },1500);
}

function typeVal(el,v){let i=0;const t=setInterval(()=>{el.value+=v[i];i++;if(i>=v.length)clearInterval(t);},20);}

// PAGE 2
const CL={
  krs:[
    {id:'kc1',name:'Вместимость ≥ 500 голов',desc:'Обязательно для мясного субсидирования (Hard Filter)',pts:12,cat:'e',req:true},
    {id:'kc2',name:'Раскол и фиксатор с электронными весами',desc:'Данные по весу становятся достоверными — повышает доверие к заявке',pts:15,cat:'e'},
    {id:'kc3',name:'Автопоилки с подогревом и твёрдое покрытие перед кормушками',desc:'Снижение потерь поголовья в зимний период',pts:8,cat:'w'},
