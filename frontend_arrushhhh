    {id:'mc1',name:'Автономное водоснабжение и автопоилки с подогревом',desc:'Независимый водозабор — стабильность производства',pts:8,cat:'w'},
    {id:'mc2',name:'Лаборатория анализа молока (соматика, жир, белок)',desc:'Подтверждение качества экстра-класса',pts:10,cat:'e'},
    {id:'mc3',name:'Холодильные установки (охлаждение до +4°C за 2 ч)',desc:'Соответствие нормам хранения',pts:7,cat:'e'},
    {id:'mc4',name:'Сертификат ХАССП или ИСО 22000',desc:'Приоритет в субсидировании, доступ к экспорту',pts:5,cat:'c'},
