  S.normScore=Math.min(15,S.normScore+8-(errs*2));
}

function calcMilk(){
  const curr=parseFloat(document.getElementById('f6-curr').value)||0;
  const prev=parseFloat(document.getElementById('f6-prev').value)||0;
  if(!curr||!prev)return;
  const pct=((curr-prev)/prev*100).toFixed(1);const g=parseFloat(pct);
  const n=document.getElementById('f6-growth-note');
  if(g>12){S.prodScore=25;n.textContent=`✓ Рост +${pct}% → Merit Score +25 баллов`;n.className='fnote ok';}
  else if(g>0){S.prodScore=15;n.textContent=`✓ Рост +${pct}% → Merit Score +15 баллов`;n.className='fnote ok';}
  else{S.prodScore=0;n.textContent=`✗ Снижение ${pct}% — баллы не начисляются`;n.className='fnote err';}
  document.getElementById('f6-ai').style.display='block';
  document.getElementById('f6-ai-text').innerHTML=`Динамика производства молока: <strong style="color:${g>0?'var(--accent)':'var(--red)'}">${g>0?'+':''}${pct}%</strong> к прошлому году.<br>AI Logic (Форма 1-ВПЖ): ${g>12?'Отличный рост — Merit Score +25.':g>0?'Положительная динамика — Merit Score +15.':'Снижение объёма — баллы по этому фактору не начисляются.'}`;
}

function checkSomatic(){
  const v=parseFloat(document.getElementById('f6-somatic').value)||0;if(!v)return;
  const n=document.getElementById('f6-somatic-note');const m=document.getElementById('somatic-meter');
  const bar=document.getElementById('qm-bar');const grade=document.getElementById('qm-grade');
  m.style.display='block';
  let pct,col,gt;
  if(v<200){pct=20;col='#4ade80';gt='Экстра-класс (<200 тыс./мл) — Merit Score +5 баллов';n.textContent='✓ Экстра-класс! Максимальный балл качества.';n.className='fnote ok';S.normScore=Math.min(15,S.normScore+5);}
  else if(v<=400){pct=50;col='#86efac';gt='Норма (200–400 тыс./мл) — Merit Score +2 балла';n.textContent='✓ В норме — соответствует ГОСТ.';n.className='fnote ok';S.normScore=Math.min(15,S.normScore+2);}
  else if(v<=500){pct=75;col='#fb923c';gt='Риск (400–500 тыс./мл) — балл снижается';n.textContent='⚠ Повышенное содержание — балл снижен.';n.className='fnote warn';S.normScore=Math.max(0,S.normScore-2);}
  else{pct=100;col='#f87171';gt='Отклонение (>500 тыс./мл) — субсидия может быть отклонена';n.textContent='✗ Превышение нормы — заявка может быть отклонена.';n.className='fnote err';S.normScore=Math.max(0,S.normScore-5);}
  bar.style.width=pct+'%';bar.style.background=col;grade.textContent=gt;grade.style.color=col;
}

function checkCowAge(){
  const type=document.getElementById('f6-cow-type').value;const age=parseInt(document.getElementById('f6-cow-age').value)||0;
  const n=document.getElementById('f6-age-note');if(!type||!age)return;
  const min=type==='breed'?23:28;
  if(age>=min){n.textContent=`✓ ${age} мес ≥ ${min} мес — норма для ${type==='breed'?'племенных':'товарных'} коров.`;n.className='fnote ok';S.normScore=Math.min(15,S.normScore+2);}
  else{n.textContent=`✗ ${age} мес < ${min} мес (мин. для ${type==='breed'?'племенных':'товарных'}).`;n.className='fnote err';}
}

function chkBuyer(id,noteId){
  const v=document.getElementById(id).value.replace(/\D/g,'').slice(0,12);document.getElementById(id).value=v;
  const n=document.getElementById(noteId);
