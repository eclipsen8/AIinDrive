  meat:[
    {id:'pc1',name:'Промышленные электронные весы 1–5 тонн',desc:'Точность взвешивания туш и живого скота',pts:10,cat:'e'},
    {id:'pc2',name:'Сертификат ХАССП (обязателен для мясокомбинатов)',desc:'Без ХАССП субсидия не предоставляется',pts:12,cat:'c',req:true},
    {id:'pc3',name:'Холодильные камеры от –18°C',desc:'Хранение продукции по нормам',pts:8,cat:'e'},
