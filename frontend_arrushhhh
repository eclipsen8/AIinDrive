    {inzh:'KZ-ATB-0246',sex:'Тёлка',breed:'Казахская белоголовая',age:16,ok:true},
  ];
  const tbody=document.getElementById('animals-tbody');tbody.innerHTML='';let errs=0;
  animals.forEach(a=>{if(!a.ok)errs++;const tr=document.createElement('tr');tr.innerHTML=`<td style="font-family:var(--mono)">${a.inzh}</td><td>${a.sex}</td><td>${a.breed}</td><td style="font-family:var(--mono)">${a.age}</td><td class="${a.ok?'s-ok':'s-err'}" style="font-family:var(--mono);font-size:10px">${a.ok?'✓ OK':'✗ '+a.reason}</td>`;tbody.appendChild(tr);});
